{
  "name": "pact-contract-testing",
  "version": "1.0.0",
  "description": "Pact consumer and provider contract testing with Jest",
  "scripts": {
    "test:consumer": "jest --testPathPattern=consumer --verbose",
    "test:provider": "node --no-deprecation node_modules/.bin/jest --testPathPattern=provider --verbose",
    "test": "jest --verbose --runInBand --testSequencer ./scripts/test-sequencer.js",
    "pact:publish": "echo 'Publishing is handled in CI via curl — see .github/workflows/contract-tests.yml'"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^13.1.4",
    "jest": "^29.7.0",
    "axios": "^1.7.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  }
}
